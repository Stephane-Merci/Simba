generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quai {
  id          String       @id @default(cuid())
  nom         String
  description String?
  ordre       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignments Assignment[]
}

model ParkingSection {
  id        String   @id @default(cuid())
  nom       String
  capacite  Int      @default(10)
  ordre     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  camions   Camion[]
}

model Camion {
  id               String          @id @default(cuid())
  matricule        String          @unique
  transporteur     String?
  type             String?         @default("Standard")
  status           String          @default("PARTI") // PARTI, PARKING, A_QUAI
  parkingSectionId String?
  parkingSection   ParkingSection? @relation(fields: [parkingSectionId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  assignments      Assignment[]
}

model Assignment {
  id           String    @id @default(cuid())
  quaiId       String
  camionId     String
  arrivee      DateTime  @default(now())
  depart       DateTime?
  dureeMinutes Int?
  notes        String?
  createdAt    DateTime  @default(now())
  quai         Quai      @relation(fields: [quaiId], references: [id], onDelete: Cascade)
  camion       Camion    @relation(fields: [camionId], references: [id], onDelete: Cascade)
}

